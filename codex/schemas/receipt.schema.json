{
  "$id": "https://github.com/rossbuckley1990-hash/Howdex/codex/schemas/receipt.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "anyOf": [
    {
      "required": [
        "procedure_id"
      ]
    },
    {
      "required": [
        "task_signature"
      ]
    }
  ],
  "description": "Run-specific verification evidence for a Howdex Codex procedure.",
  "properties": {
    "artifact_hashes": {
      "additionalProperties": {
        "minLength": 1,
        "type": "string"
      },
      "type": "object"
    },
    "environment": {
      "additionalProperties": {
        "type": [
          "string",
          "number",
          "boolean",
          "null"
        ]
      },
      "type": "object"
    },
    "environment_fingerprint": {
      "additionalProperties": {
        "type": [
          "string",
          "number",
          "boolean",
          "null"
        ]
      },
      "type": "object"
    },
    "exit_code": {
      "type": "integer"
    },
    "expected_signal": {
      "minLength": 1,
      "type": "string"
    },
    "observed_signal": {
      "minLength": 1,
      "type": "string"
    },
    "procedure_id": {
      "minLength": 1,
      "type": "string"
    },
    "receipt_id": {
      "minLength": 1,
      "type": "string"
    },
    "source_episode_id": {
      "minLength": 1,
      "type": "string"
    },
    "status": {
      "enum": [
        "verified",
        "failed",
        "stale",
        "unknown"
      ],
      "type": "string"
    },
    "task_signature": {
      "minLength": 1,
      "type": "string"
    },
    "verified_at": {
      "format": "date-time",
      "type": "string"
    },
    "verifier_command": {
      "minLength": 1,
      "type": "string"
    },
    "verifier_type": {
      "minLength": 1,
      "type": "string"
    }
  },
  "required": [
    "receipt_id",
    "verifier_type",
    "verifier_command",
    "expected_signal",
    "observed_signal",
    "exit_code",
    "verified_at",
    "environment_fingerprint",
    "artifact_hashes",
    "source_episode_id",
    "status"
  ],
  "title": "Howdex Codex Verification Receipt",
  "type": "object"
}
